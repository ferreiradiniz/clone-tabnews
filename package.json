{
  "name": "clone-tabnews",
  "version": "1.0.0",
  "description": "treinamento",
  "main": "index.js",
  "scripts": {
    "dev": "npm run service:up && next dev",
    "lint:check": "prettier --check .",
    "lint:fix": "prettier --write .",
    "test": "jest",
    "test:watch": "jest --watchAll --all",
    "service:up": "docker compose -f infra/compose.yaml up -d",
    "service:stop": "docker compose -f infra/compose.yaml stop",
    "service:down": "docker compose -f infra/compose.yaml down -v",
    "migration:create": "node-pg-migrate -m infra/migrations create",
    "migration:up": "node-pg-migrate -m infra/migrations --envPath .env.development up",
    "migrate": "node-pg-migrate -m infra/migrations"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv-expand": "^11.0.6",
    "next": "^15.5.12",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "jest": "^30.2.0",
    "node-pg-migrate": "^6.2.2",
    "prettier": "^3.8.1"
  }
}
